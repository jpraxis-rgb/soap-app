{
  "expo": {
    "name": "Estuda Tudo",
    "slug": "estudatudo",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "soap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soap.app"
    },
    "android": {
      "package": "com.soap.app",
      "adaptiveIcon": {
        "backgroundColor": "#6D28D9"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.992045506382-ttk81obo6v4fk2i3cks6pjb5drfrbr34"
        }
      ]
    ]
  }
}
