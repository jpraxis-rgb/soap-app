# Database
DATABASE_URL=postgresql://user:password@localhost:5432/soap

# JWT — BOTH are required in production (the server refuses to boot without them).
# Generate strong random values, e.g. `openssl rand -hex 32`. Never reuse the same
# value for both, and never rely on a default.
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-separate-refresh-secret-here

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple Sign-In — the token audience(s). Comma-separated if you support both
# native (the app bundle id, e.g. com.estudatudo.app) and web (your Services ID).
# Leave empty to disable Apple sign-in (endpoint returns 503 "not configured").
APPLE_CLIENT_ID=

# Web frontend origin used for OAuth redirect callbacks (must match the deployed
# web domain, e.g. https://app.estudatudo.com). Defaults to localhost in dev.
FRONTEND_URL=http://localhost:8081

# Comma-separated CORS allowlist. When set, only these origins are accepted.
# Leave unset in local dev to reflect any origin.
CORS_ORIGINS=

# Set to 'true' ONLY for local development to auto-authenticate as a demo user.
# Has no effect when NODE_ENV=production.
ENABLE_DEV_AUTH=false

# Expo
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Push Notifications
EXPO_ACCESS_TOKEN=your-expo-access-token

# Payments (TBD)
PAYMENT_GATEWAY_KEY=
PAYMENT_GATEWAY_SECRET=

# Environment
NODE_ENV=development
PORT=3000
