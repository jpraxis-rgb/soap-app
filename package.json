{
  "name": "soap-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/mobile\"",
    "build": "npm run build -w packages/shared && npm run build -w apps/api",
    "typecheck": "tsc --noEmit -p packages/shared/tsconfig.json && tsc --noEmit -p apps/api/tsconfig.json",
    "lint": "eslint .",
    "test": "npm run test --workspace=apps/api",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:generate": "npm run db:generate -w apps/api"
  },
  "dependencies": {
    "expo-blur": "~55.0.9",
    "react-native-worklets": "0.7.2"
  },
  "overrides": {
    "react-native-worklets": "$react-native-worklets"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
